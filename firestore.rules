rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: only the owner can read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Writings: user's projects and sections
    match /users/{userId}/writings/{writingId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/writings/{writingId}/sections/{sectionId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Feed items: anyone authenticated can read; only backend/admin writes
    match /feed_items/{itemId} {
      allow read: if request.auth != null;
      allow write: if false; // Use Admin SDK or Cloud Functions to add items
    }
  }
}
